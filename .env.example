# Supabase — project URL and keys (https://app.supabase.com -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PostHog — product analytics (leave empty to disable; app runs without it)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Stripe — payments (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# App — public base URL used for redirects and webhooks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe price IDs for the subscription plans (Dashboard -> Products)
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=

# Upstash Redis — optional. If set, rate limiting is shared across instances;
# otherwise an in-process sliding-window limiter is used (see lib/ratelimit.ts).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
